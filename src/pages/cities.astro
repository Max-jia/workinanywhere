---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import chiangMaiTemple from '../assets/chiang-mai-temple.jpg';
import cityMedellin from '../assets/city-medellin.jpg';
import lisbonCity from '../assets/lisbon-city.jpg';
import daNangBeach from '../assets/da-nang-beach.jpg';
import baliTemple from '../assets/bali-temple.jpg';
import barcelonaNew from '../assets/barcelona-new.jpg';
import tbilisiNew from '../assets/tbilisi-new.jpg';
import cityTokyo from '../assets/city-tokyo.jpg';
import mexicoCityAerial from '../assets/mexico-city-aerial.jpg';
import newZealandMountain from '../assets/new-zealand-mountain.jpg';
import costaRicaNature from '../assets/costa-rica-nature.jpg';
import croatiaCity from '../assets/croatia-city.jpg';
import bulgariaSofia from '../assets/bulgaria-sofia.jpg';
import cityValencia from '../assets/city-valencia.jpg';
import japanNagasaki from '../assets/japan-nagasaki.jpg';
import buenosAiresCity from '../assets/buenos-aires-city.jpg';

const cities = [
  { slug: 'chiang-mai', name: 'Chiang Mai', country: 'Thailand', flag: '🇹🇭', cost: '$600-900/mo', img: chiangMaiTemple, desc: 'The most popular first stop for digital nomads. Reliable infrastructure, huge community, unbeatable value.' },
  { slug: 'medellin', name: 'Medellin', country: 'Colombia', flag: '🇨🇴', cost: '$800-1,200/mo', img: cityMedellin, desc: 'Springlike climate, 2-year DN visa, and the strongest nomad community in Latin America.' },
  { slug: 'lisbon', name: 'Lisbon', country: 'Portugal', flag: '🇵🇹', cost: '$1,500-2,200/mo', img: lisbonCity, desc: 'Europe\'s entry point. Sun, sea, and a path to EU residency through the D8 visa.' },
  { slug: 'da-nang', name: 'Da Nang', country: 'Vietnam', flag: '🇻🇳', cost: '$650-900/mo', img: daNangBeach, desc: 'Southeast Asia\'s best-value beach city. Clean, modern, still under the radar.' },
  { slug: 'bali', name: 'Bali', country: 'Indonesia', flag: '🇮🇩', cost: '$800-1,300/mo', img: baliTemple, desc: 'Coworking culture, surf towns, rice terraces. A nomad scene that has evolved beyond backpackers.' },
  { slug: 'barcelona', name: 'Barcelona', country: 'Spain', flag: '🇪🇸', cost: '$1,600-2,400/mo', img: barcelonaNew, desc: 'Mediterranean lifestyle, world-class architecture, thriving remote work community.' },
  { slug: 'tbilisi', name: 'Tbilisi', country: 'Georgia', flag: '🇬🇪', cost: '$700-1,100/mo', img: tbilisiNew, desc: '1-year visa-free, 1% small business tax, and a creative scene that punches above its weight.' },
  { slug: 'tokyo', name: 'Tokyo', country: 'Japan', flag: '🇯🇵', cost: '$1,400-2,200/mo', img: cityTokyo, desc: 'Weak yen makes Tokyo accessible. World-class infrastructure at a fraction of the old cost.' },
  { slug: 'mexico-city', name: 'Mexico City', country: 'Mexico', flag: '🇲🇽', cost: '$1,000-1,600/mo', img: mexicoCityAerial, desc: 'A cultural powerhouse with neighborhoods purpose-built for remote workers.' },
  { slug: 'buenos-aires', name: 'Buenos Aires', country: 'Argentina', flag: '🇦🇷', cost: '$800-1,300/mo', img: buenosAiresCity, desc: 'European architecture, Latin energy, favorable for dollar earners.' },
  { slug: 'new-zealand', name: 'New Zealand', country: 'New Zealand', flag: '🇳🇿', cost: '$2,000-2,800/mo', img: newZealandMountain, desc: 'Stunning nature, relaxed visa rules, rock-solid infrastructure.' },
  { slug: 'costa-rica', name: 'Costa Rica', country: 'Costa Rica', flag: '🇨🇷', cost: '$1,200-2,000/mo', img: costaRicaNature, desc: 'Pura vida lifestyle. Straightforward DN visa, two coastlines, nature everywhere.' },
  { slug: 'croatia', name: 'Croatia', country: 'Croatia', flag: '🇭🇷', cost: '$1,500-2,200/mo', img: croatiaCity, desc: 'First EU DN visa. Adriatic coast, fast fiber, Mediterranean living at a discount.' },
  { slug: 'bulgaria', name: 'Bulgaria', country: 'Bulgaria', flag: '🇧🇬', cost: '$600-1,000/mo', img: bulgariaSofia, desc: 'EU\'s cheapest country. Flat 10% tax, fast internet, growing remote work community.' },
  { slug: 'valencia', name: 'Valencia', country: 'Spain', flag: '🇪🇸', cost: '$1,300-1,900/mo', img: cityValencia, desc: 'Barcelona\'s affordable sibling. Beach, paella, fast-growing nomad scene.' },
  { slug: 'nagasaki', name: 'Nagasaki', country: 'Japan', flag: '🇯🇵', cost: '$900-1,500/mo', img: japanNagasaki, desc: 'Japan is paying remote workers to live here. Lower costs than Tokyo, rich history.' },
];

const pageTitle = 'Nomad Cities: Compare Cost, Internet, and Lifestyle in 2026';
const pageDesc = 'Browse the best cities for digital nomads. Real cost of living, internet speeds, and honest pros and cons for 16 destinations.';
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <main>
    <section class="hero">
      <h1 class="hero-title">Nomad Cities</h1>
      <p class="hero-subtitle">16 destinations with real cost data, visa guides, and firsthand advice. Click a city to explore everything we have written about it.</p>
    </section>

    <div class="city-grid">
      {cities.map((c) => (
        <a href={`/cities/${c.slug}`} class="city-card reveal">
          <div class="city-img">
            <Image src={c.img} alt={c.name} width={400} height={240} />
            <div class="city-img-overlay"></div>
            <span class="city-cost-tag">{c.cost}</span>
          </div>
          <div class="city-body">
            <h2 class="city-name"><span class="city-flag">{c.flag}</span> {c.name}</h2>
            <p class="city-country">{c.country}</p>
            <p class="city-desc">{c.desc}</p>
          </div>
        </a>
      ))}
    </div>

    <footer class="page-footer">
      <p>We add new city guides regularly. Last updated: July 2026.</p>
      <nav>
        <a href="/blog">All articles</a>
        <a href="/about">About</a>
      </nav>
    </footer>
  </main>
</BaseLayout>

<style>
  main { max-width: var(--max-width-wide); margin: 0 auto; padding: 0 2em 3em; }

  .hero { text-align: center; padding: 3em 0 2em; }
  .hero-title { font-family: var(--font-heading); font-size: clamp(2rem, 5vw, 3rem); font-weight: 400; color: var(--color-text-heading); margin-bottom: 0.4em; }
  .hero-subtitle { font-size: 1rem; color: var(--color-text-muted); max-width: 520px; margin: 0 auto; }
  @media (prefers-color-scheme: dark) { .hero-title { color: var(--color-text-heading-dark); } }

  .city-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2em; margin-top: 1.5em; }

  .city-card {
    background: var(--color-elevated); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: var(--shadow-card); display: flex; flex-direction: column;
  }
  .city-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-card-hover); }
  @media (prefers-color-scheme: dark) { .city-card { background: var(--color-elevated-dark); border-color: var(--color-border-dark); } }

  .city-img { position: relative; overflow: hidden; }
  .city-img img { width: 100%; aspect-ratio: 16/10; object-fit: cover; border-radius: 0; display: block; transition: transform 0.3s; }
  .city-card:hover .city-img img { transform: scale(1.04); }
  .city-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(26,31,29,0.3) 0%, transparent 50%); }
  .city-cost-tag {
    position: absolute; bottom: 10px; right: 10px;
    font-size: 0.7rem; font-weight: 600; color: #fff;
    background: rgba(0,0,0,0.55); backdrop-filter: blur(6px);
    padding: 0.25em 0.7em; border-radius: 100px;
  }

  .city-body { padding: 1em 1.2em 1.2em; flex: 1; display: flex; flex-direction: column; }
  .city-name { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 400; color: var(--color-text-heading); margin: 0; display: flex; align-items: center; gap: 0.4em; }
  .city-flag { font-size: 1.2rem; }
  .city-country { font-size: 0.72rem; color: var(--color-text-muted); margin: 0.15em 0 0.5em; text-transform: uppercase; letter-spacing: 0.04em; }
  .city-desc { font-size: 0.82rem; color: var(--color-text-muted); line-height: 1.45; margin: 0; flex: 1; }
  @media (prefers-color-scheme: dark) { .city-name { color: var(--color-text-heading-dark); } }

  .page-footer { text-align: center; margin-top: 3em; padding-top: 2em; border-top: 1px solid var(--color-border); }
  .page-footer p { font-size: 0.82rem; color: var(--color-text-muted); margin: 0 0 0.5em; }
  .page-footer nav { display: flex; justify-content: center; gap: 1.5em; }
  .page-footer nav a { font-size: 0.82rem; color: var(--color-text-muted); }

  @media (max-width: 600px) {
    main { padding: 0 1em 2em; }
    .city-grid { grid-template-columns: 1fr 1fr; gap: 0.8em; }
    .hero { padding: 2em 0 1em; }
    .city-body { padding: 0.8em; }
    .city-name { font-size: 0.9rem; }
    .city-desc { font-size: 0.72rem; }
  }
  @media (max-width: 400px) { .city-grid { grid-template-columns: 1fr; } }
</style>
