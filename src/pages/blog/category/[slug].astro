---
import { getCollection } from 'astro:content';
import ArticleCard from '../../../components/ArticleCard.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { CATEGORIES } from '../../../consts';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { slug: cat.slug } }));
}

const { slug } = Astro.params;
const category = CATEGORIES.find((c) => c.slug === slug);
if (!category) return new Response('Not found', { status: 404 });

const posts = (await getCollection('blog'))
  .filter((p) => p.data.category === slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={`${category.label} — Work Anywhere`}
  description={`Articles about ${category.label.toLowerCase()} for remote workers.`}
>
  <main>
    <h1 class="page-title">{category.label}</h1>
    <p class="page-count">{posts.length} articles</p>

    <nav class="page-nav">
      {CATEGORIES.map((cat) => (
        <a href={`/blog/category/${cat.slug}`} class:list={[cat.slug === slug ? 'current' : '']}>
          {cat.label}
        </a>
      ))}
      <a href="/blog">All articles</a>
    </nav>

    {posts.length > 0 ? (
      <div class="grid-2col">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            href={`/blog/${post.id}`}
            heroImage={post.data.heroImage}
          />
        ))}
      </div>
    ) : (
      <p class="empty">No articles yet.</p>
    )}
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 3em 1.5em 4em;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 0.2em;
  }

  .page-count {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5em;
  }

  .page-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25em 1.2em;
    padding-bottom: 1.5em;
    margin-bottom: 2em;
    border-bottom: 1px solid var(--color-border);
  }

  .page-nav a {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .page-nav a:hover { color: var(--color-text-heading); }
  .page-nav a.current { color: var(--color-accent); }

  @media (prefers-color-scheme: dark) {
    .page-nav { border-color: var(--color-border-dark); }
  }

  .grid-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5em;
  }

  .empty {
    color: var(--color-text-muted);
    padding: 2em 0;
  }

  @media (max-width: 700px) {
    .grid-2col { grid-template-columns: 1fr; }
  }
</style>
