---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <p>&copy; {today.getFullYear()} Work Anywhere</p>
    <div class="footer-links">
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="/privacy">Privacy</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4em;
    padding: 1.5em 1.5em 3em;
    font-size: 0.8rem;
  }

  @media (prefers-color-scheme: dark) {
    footer { border-top-color: var(--color-border-dark); }
  }

  .footer-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-text-muted);
  }

  .footer-inner p { margin: 0; }

  .footer-links { display: flex; gap: 1.5em; }
  .footer-links a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .footer-links a:hover { color: var(--color-text-heading); }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; text-align: center; gap: 0.5em; }
  }
</style>
