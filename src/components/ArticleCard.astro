---
import { Image } from 'astro:assets';
import { CATEGORIES } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category?: string;
  href: string;
  heroImage?: any;
}

const { title, description, pubDate, category, href, heroImage } = Astro.props;
const catMeta = CATEGORIES.find((c) => c.slug === category);

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<a href={href} class="card reveal">
  {heroImage && (
    <div class="card-image">
      <Image src={heroImage} alt={title} width={600} height={340} />
    </div>
  )}
  <div class="card-body">
    <div class="card-meta">
      {catMeta && <span class="card-cat">{catMeta.label}</span>}
      <span class="card-dot">&middot;</span>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>
    <h2 class="card-title">{title}</h2>
    <p class="card-desc">{description}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--color-surface);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: var(--shadow-card);
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover), 0 0 0 1px var(--color-accent);
  }

  @media (prefers-color-scheme: dark) {
    .card { background: var(--color-surface-dark); }
  }

  .card-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .card-body {
    padding: 1em 1em 1.3em;
  }

  .card-meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.4em;
    margin-bottom: 0.4em;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-cat {
    font-weight: 600;
    color: var(--color-accent);
  }

  .card-dot {
    opacity: 0.4;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-heading);
    margin: 0 0 0.25em;
  }

  @media (prefers-color-scheme: dark) {
    .card-title { color: var(--color-text-heading-dark); }
  }

  .card-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card:hover .card-title {
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 4px;
  }
</style>
