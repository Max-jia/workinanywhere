---
interface Props {
  slot?: 'article' | 'sidebar' | 'footer';
}
const { slot = 'article' } = Astro.props;
---

<div class="ad-container" data-ad-slot={slot}>
  <span class="ad-label">Advertisement</span>
  <ins class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-7649257223930816"
    data-ad-slot="1234567890"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>

<style>
  .ad-container {
    min-height: 120px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    margin: 2em 0;
    position: relative;
  }
  .ad-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    position: absolute;
    top: -1.2em; left: 0;
  }
  @media (prefers-color-scheme: dark) {
    .ad-container { background: var(--color-surface-dark); border-color: var(--color-border-dark); }
  }
</style>
