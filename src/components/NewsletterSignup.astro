---
// 邮件订阅组件 — 替换 action URL 为你的邮件服务商链接
// ConvertKit 免费版: https://app.convertkit.com/forms/landing_pages/YOUR_ID/subscribe
// MailerLite 免费版: https://dashboard.mailerlite.com/forms/YOUR_ID/YOUR_FORM_ID/subscribe
const formAction = "https://app.convertkit.com/forms/landing_pages/YOUR_ID/subscribe";
---

<div class="newsletter-signup">
  <h3 class="nl-title">Get one useful article every week</h3>
  <p class="nl-desc">No spam. No AI fluff. Just practical tips on remote work, nomad cities, tools, and money — from someone who actually lives this way.</p>
  <form action={formAction} method="post" class="nl-form">
    <input type="email" name="email" placeholder="Your email address" required class="nl-input" aria-label="Email address" />
    <button type="submit" class="nl-button">Subscribe</button>
  </form>
  <p class="nl-disclaimer">Unsubscribe anytime. No spam, ever.</p>
</div>

<style>
  .newsletter-signup {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2em 2em 1.5em;
    text-align: center;
    max-width: 480px;
    margin: 3em auto;
  }
  @media (prefers-color-scheme: dark) {
    .newsletter-signup { background: var(--color-surface-dark); border-color: var(--color-border-dark); }
  }
  .nl-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text-heading);
    margin: 0 0 0.4em;
  }
  .nl-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 1em;
  }
  .nl-form {
    display: flex;
    gap: 0.5em;
    max-width: 380px;
    margin: 0 auto;
  }
  .nl-input {
    flex: 1;
    font-size: 0.9rem;
    padding: 0.7em 1em;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    min-width: 0;
  }
  .nl-input:focus { border-color: var(--color-accent); }
  .nl-button {
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.7em 1.4em;
    background: var(--color-text-heading);
    color: var(--color-bg);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .nl-button:hover { opacity: 0.85; }
  @media (prefers-color-scheme: dark) {
    .nl-button { background: var(--color-text-heading-dark); color: var(--color-bg-dark); }
    .nl-input { background: var(--color-bg-dark); border-color: var(--color-border-dark); color: var(--color-text-dark); }
  }
  .nl-disclaimer { font-size: 0.7rem; color: var(--color-text-muted); margin: 0.8em 0 0; opacity: 0.6; }
  @media (max-width: 500px) {
    .nl-form { flex-direction: column; }
    .newsletter-signup { padding: 1.5em 1.2em; }
  }
</style>
